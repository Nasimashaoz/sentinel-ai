{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Sentinel AI — Security Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "🚨 Critical Threats (24h)",
      "type": "stat",
      "targets": [{"expr": "increase(sentinel_threats_total{risk=\"CRITICAL\"}[24h])", "legendFormat": "Critical"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 10}, {"color": "red", "value": 50}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "🔴 High Threats (24h)",
      "type": "stat",
      "targets": [{"expr": "increase(sentinel_threats_total{risk=\"HIGH\"}[24h])", "legendFormat": "High"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "title": "📊 Total Incidents (all time)",
      "type": "stat",
      "targets": [{"expr": "sentinel_threats_total", "legendFormat": "Total"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 600}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "⏱️ Agent Uptime",
      "type": "stat",
      "targets": [{"expr": "sentinel_uptime_seconds", "legendFormat": "Uptime"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 15}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "CRITICAL"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "HIGH"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "MEDIUM"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 4},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "📈 Threat Rate Over Time",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(sentinel_threats_total{risk=\"CRITICAL\"}[5m]) * 60", "legendFormat": "CRITICAL"},
        {"expr": "rate(sentinel_threats_total{risk=\"HIGH\"}[5m]) * 60", "legendFormat": "HIGH"},
        {"expr": "rate(sentinel_threats_total{risk=\"MEDIUM\"}[5m]) * 60", "legendFormat": "MEDIUM"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"displayMode": "gradient-gauge"}}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal"},
      "title": "🎯 Threats by Type",
      "type": "bargauge",
      "targets": [{"expr": "topk(5, sentinel_threats_by_type_total)", "legendFormat": "{{type}}"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "IP"}, "properties": [{"id": "custom.width", "value": 150}]},
          {"matcher": {"id": "byName", "options": "Count"}, "properties": [{"id": "custom.width", "value": 80}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"sortBy": [{"displayName": "Count", "desc": true}]},
      "title": "🌍 Top Attacker IPs",
      "type": "table",
      "targets": [{"expr": "topk(10, sentinel_threats_by_ip_total)", "legendFormat": "{{source_ip}}", "instant": true, "format": "table"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "title": "🖥️ Multi-Server Overview",
      "type": "timeseries",
      "targets": [{"expr": "sentinel_threats_total", "legendFormat": "{{server}}"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["security", "sentinel-ai", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "server",
        "query": "label_values(sentinel_threats_total, server)",
        "refresh": 2,
        "type": "query",
        "label": "Server"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Sentinel AI — Security Dashboard",
  "uid": "sentinel-ai-v1",
  "version": 1
}
