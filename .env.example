# =============================================================
# Sentinel AI — Environment Configuration
# Copy to .env and fill in your values
# cp .env.example .env
# =============================================================

# ----- AI Engine (choose one or both) ------------------------
# Claude AI (https://console.anthropic.com)
CLAUDE_API_KEY=your_claude_api_key_here

# Ollama (self-hosted, no API key needed)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ----- Monitoring Settings -----------------------------------
SCAN_INTERVAL=60               # seconds between scans
MIN_RISK_TO_ALERT=HIGH         # LOW | MEDIUM | HIGH | CRITICAL
LOG_LEVEL=INFO

# ----- Alert Channels (enable what you use) ------------------

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# WhatsApp (via Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+YOUR_NUMBER

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=security@yourcompany.com

# PagerDuty (on-call escalation)
PAGERDUTY_ROUTING_KEY=your_pagerduty_integration_key
PAGERDUTY_CRITICAL_ONLY=true

# Signal Messenger (requires signal-cli-rest-api)
SIGNAL_API_URL=http://localhost:8085
SIGNAL_SENDER=+1234567890
SIGNAL_RECIPIENTS=+0987654321
SIGNAL_MIN_RISK=HIGH

# ----- Threat Intelligence -----------------------------------
ABUSEIPDB_API_KEY=your_abuseipdb_key     # https://www.abuseipdb.com/api (free)
VIRUSTOTAL_API_KEY=your_virustotal_key   # https://www.virustotal.com (free)
THREAT_INTEL_CACHE_HOURS=24
THREAT_INTEL_MIN_SCORE=20               # AbuseIPDB % threshold

# ----- Cloud Collectors --------------------------------------

# Kubernetes
K8S_ENABLED=false
K8S_NAMESPACE=                          # empty = all namespaces

# AWS CloudTrail
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
# Or use IAM role / instance profile (recommended for EC2/EKS)

# Google Cloud Platform
GCP_ENABLED=false
GCP_PROJECT_ID=your-project-id
GCP_LOOKBACK_MINUTES=5
GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Azure
AZURE_ENABLED=false
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_LOOKBACK_MINUTES=5

# ----- Auto-Remediation (DISABLED by default) ----------------
AUTO_REMEDIATE=false           # set true to enable safe auto-actions
AUTO_REMEDIATE_CRITICAL=false  # extra gate for CRITICAL threats

# ----- Dashboard & Metrics -----------------------------------
DASHBOARD_PORT=8080
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true
